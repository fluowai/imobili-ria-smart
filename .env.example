# Copie este arquivo como .env e preencha com os valores do seu projeto Supabase
# (Project Settings → API)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-publishable-key-aqui

# URL do serviço whatsmeow (Go).
# - Em produção com docker-compose + Caddy: deixe /wa
# - Em dev apontando pra um VPS: https://seu-vps.com:8080  (ou http://IP:8080)
# Se vazio, cai no default "/wa".
VITE_WHATSMEOW_URL=/wa
