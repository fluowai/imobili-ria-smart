# Domínio público (Caddy). Use "localhost" para dev local.
DOMAIN=localhost

# Postgres local (dados operacionais além do Supabase)
POSTGRES_PASSWORD=troque-esta-senha

# Auth
JWT_SECRET=gere-uma-string-aleatoria-de-64-chars

# MinIO (S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=troque-esta-senha
S3_BUCKET=documentos

# ===== whatsmeow (WhatsApp real) =====
# Postgres do Supabase (Settings → Database → Connection string → URI).
# O whatsmeow-svc cria o schema `whatsmeow` automaticamente.
SUPABASE_DB_URL=postgres://postgres:SENHA@db.SEUREF.supabase.co:5432/postgres?sslmode=require

# Supabase JWT Secret (Settings → API → JWT Settings → JWT Secret).
# Necessário para validar o access token do usuário logado.
SUPABASE_JWT_SECRET=cole-o-jwt-secret-do-supabase
