# Substitua seu-dominio.com pelo domínio real em produção.
# Em desenvolvimento local, use :80 no lugar do bloco de domínio.

{$DOMAIN:localhost} {
	encode zstd gzip

	# whatsmeow (SSE precisa de flush/streaming — Caddy já faz por padrão em reverse_proxy)
	handle_path /wa/* {
		reverse_proxy whatsmeow:8080 {
			flush_interval -1
		}
	}

	reverse_proxy app:3000
}
